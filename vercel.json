{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/order-enquiry",
      "dest": "/api/order-enquiry.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/robots.txt",
      "dest": "/api/robots.js"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap.js"
    },
    {
      "src": "/index.html",
      "dest": "/api/site-enhanced.js"
    },
    {
      "src": "/",
      "dest": "/api/site-enhanced.js"
    },
    {
      "src": "/products/?",
      "dest": "/api/site-enhanced.js"
    },
    {
      "src": "/products/([^/]+)/?",
      "dest": "/api/product-cached.js?product=$1"
    },
    {
      "src": "/shop/?",
      "dest": "/api/site-enhanced.js"
    },
    {
      "src": "/checkout/?",
      "dest": "/api/site-enhanced.js"
    },
    {
      "src": "/contacts/?",
      "dest": "/api/site-enhanced.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/site-enhanced.js"
    }
  ]
}
